{
  "manifest_version": 3,

  "name": "Subtaitoru",
  "description": "Learn japanese while watching your favorite movie/anime with this Chrome Extension",
  "version": "1.3",

  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["profile.html"]
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://*.amazon.co.uk/*",
    "*://*.amazon.com/*",
    "*://*.amazon.de/*",
    "*://*.amazon.fr/*",
    "*://*.amazon.it/*",
    "*://*.amazon.es/*",
    "*://*.amazon.ca/*",
    "*://*.amazon.cn/*",
    "*://*.amazon.in/*",
    "*://*.amazon.co.jp/*",
    "*://*.youtube.com/*",
    "*://*.netflix.com/*",
    "*://*.kitsunekko.net/*",
    "*://*.d-addicts.com/*",
    "*://*.deepl.com/*"
  ],

  "background": {
    "service_worker": "js/background.js"
  }
}
