{
  "manifest_version": 3,
  "name": "Subtaitoru",
  "version": "1.3",
  "description": "Learn japanese while watching your favorite movie/anime with this Chrome Extension",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus"],
  "host_permissions": [
    "*://*.amazon.co.uk/*",
    "*://*.amazon.com/*",
    "*://*.amazon.de/*",
    "*://*.amazon.fr/*",
    "*://*.amazon.it/*",
    "*://*.amazon.es/*",
    "*://*.amazon.ca/*",
    "*://*.amazon.cn/*",
    "*://*.amazon.in/*",
    "*://*.amazon.co.jp/*",
    "*://*.youtube.com/*",
    "*://*.netflix.com/*",
    "*://*.kitsunekko.net/*",
    "*://*.d-addicts.com/*",
    "*://*.deepl.com/*",
    "*://*/*"
  ],
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["profile.html"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "exclude_matches": [
        "*://*.amazon.co.uk/*",
        "*://*.amazon.com/*",
        "*://*.amazon.de/*",
        "*://*.amazon.fr/*",
        "*://*.amazon.it/*",
        "*://*.amazon.es/*",
        "*://*.amazon.ca/*",
        "*://*.amazon.cn/*",
        "*://*.amazon.in/*",
        "*://*.amazon.co.jp/*",
        "*://*.youtube.com/*",
        "*://*.netflix.com/*"
      ],
      "js": ["hover_translation.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
